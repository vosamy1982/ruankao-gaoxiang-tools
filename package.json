{
  "name": "ruankao-gaoxiang-tools",
  "private": false,
  "version": "0.10.0",
  "description": "A local-first study and ITTO query tool for the Ruankao advanced project management exam.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://vosamy1982.github.io/ruankao-gaoxiang-tools/",
  "repository": {
    "type": "git",
    "url": "https://github.com/vosamy1982/ruankao-gaoxiang-tools.git"
  },
  "bugs": {
    "url": "https://github.com/vosamy1982/ruankao-gaoxiang-tools/issues"
  },
  "keywords": [
    "ruankao",
    "project-management",
    "itto",
    "study-tool",
    "react",
    "vite"
  ],
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "test": "node --experimental-strip-types --test tests/*.test.ts",
    "audit:data": "node --experimental-strip-types scripts/audit-data.ts",
    "audit:dependencies": "npm audit --omit=dev --audit-level=moderate --registry=https://registry.npmjs.org",
    "bundle:check": "node --experimental-strip-types scripts/check-bundle-size.ts",
    "check": "npm run lint && npm run test && npm run audit:data && npm run audit:dependencies && npm run build && npm run bundle:check",
    "preview": "vite preview"
  },
  "dependencies": {
    "@uiw/react-md-editor": "^4.1.1",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/formidable": "^3.5.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "formidable": "^3.5.4",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16"
  }
}
